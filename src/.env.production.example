# Plantilla de .env para PRODUCCIÓN (serviciodejardineria.com.ar).
# Copiar a .env en el servidor real y completar los valores marcados TODO.
# NUNCA commitear el .env real con secretos -- este archivo es solo la plantilla.

APP_NAME="AltoParque"
APP_ENV=production
APP_KEY=                          # TODO: generar en el servidor con `php artisan key:generate`, no reusar el de dev
APP_DEBUG=false
APP_URL=https://serviciodejardineria.com.ar

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_AR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                   # error en producción, no debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1                 # TODO: host real de MySQL en el hosting
DB_PORT=3306
DB_DATABASE=                      # TODO: nombre de la base en el hosting
DB_USERNAME=                      # TODO
DB_PASSWORD=                      # TODO

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.serviciodejardineria.com.ar   # con el punto inicial, cubre apex y www
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp                  # TODO: confirmar con el hosting (Hostinger da SMTP propio, o usar el proveedor que prefieran)
MAIL_HOST=                        # TODO
MAIL_PORT=587
MAIL_USERNAME=                    # TODO
MAIL_PASSWORD=                    # TODO
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="info@serviciodejardineria.com.ar"
MAIL_FROM_NAME="${APP_NAME}"

RECAPTCHA_SITE_KEY=                # TODO: crear en https://www.google.com/recaptcha/admin (reCAPTCHA v3) para serviciodejardineria.com.ar
RECAPTCHA_SECRET_KEY=              # TODO
RECAPTCHA_MINIMUM_SCORE=0.5

VITE_APP_NAME="${APP_NAME}"
